# Copy this file to .env and fill in real values. Never commit .env.

# --- Neo4j (graph store) ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=
# Value consumed by the neo4j container as NEO4J_AUTH=neo4j/<password>.

# --- PostgreSQL + pgvector (embeddings, reserved for a later phase) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=threatweave
POSTGRES_USER=threatweave
POSTGRES_PASSWORD=

# --- AlienVault OTX ingestion connector ---
OTX_API_KEY=
OTX_BASE_URL=https://otx.alienvault.com/api/v1

# --- LLM provider (reserved: not used until the AI enrichment phase) ---
LLM_PROVIDER=none
LLM_API_KEY=
LLM_MODEL=

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
